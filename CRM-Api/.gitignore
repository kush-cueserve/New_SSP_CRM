## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore is based on the GitHub VisualStudio.gitignore template

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache files
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docuser

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on secondary drives
$RECYCLE.BIN/

# Others
*.exe
*.dll
*.pdb
*.suo
*.ntvs*
*.njsproj
*.sln.docuser
*.user
*.publish.xml
*.swp
*~

# Environment Files
appsettings.Development.json
# appsettings.json (Optional: uncomment if you want to keep the main config local only)
